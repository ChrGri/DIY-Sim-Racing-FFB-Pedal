<UserControl x:Class="User.PluginSdkDemo.UIFunction.GeneralSetting_Servo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:User.PluginSdkDemo.UIFunction"
             xmlns:localUI="clr-namespace:User.PluginSdkDemo.UIElement"
             xmlns:localFunction="clr-namespace:User.PluginSdkDemo.UIFunction"
             xmlns:styles="clr-namespace:SimHub.Plugins.Styles;assembly=SimHub.Plugins" mc:Ignorable="d" 
             xmlns:ui="clr-namespace:SimHub.Plugins.UI;assembly=SimHub.Plugins" 
             xmlns:controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
             d:DesignHeight="190" d:DesignWidth="540"
             d:DataContext="{d:DesignInstance Type=localFunction:GeneralSetting_Servo}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/DiyActivePedal;component/UIStyles/DefaultStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Border Background="#7F4E4E4E" Height="190" CornerRadius="5,5,5,5" BorderThickness="0,2,0,0" >
            
            <StackPanel HorizontalAlignment="Left" Height="190" VerticalAlignment="Top" Width="540">
                <StackPanel Height="20" Width="540" Orientation="Horizontal">
                    <Label Content="{SLoc DIYFFBPedalPlugin_TextServoSettingTittle, 'Servo Settings'}" Height="15" Width="150" Padding="0,0,0,0" VerticalContentAlignment="Center" FontFamily="Arial Black" HorizontalAlignment="Left" Margin="70,0,0,0"/>
                </StackPanel>
                <StackPanel Width="400" Height="50">
                    <localUI:SliderWithLabel x:Name="Slider_ServoEndstopDetecionThreshold" SliderLength="400" SliderName="{SLoc DIYFFBPedalPlugin_TextServoSettingSliderEndstopCurrent, 'Endstop Detection Threshold'}" SliderValue="30" MinValue="25" MaxValue="50" SliderValueChanged="Slider_ServoEndstopDetecionThreshold_SliderValueChanged" TickFrequency="1" Unit="%" ToolTip="Increase the value if homing not get full travel. It will take effect after set the config as default and a pedal restart."/>
                </StackPanel>
                <StackPanel Height="40" Width="540" HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal">
                    <localUI:SliderWithLabel x:Name="Slider_ServoTimeout" SliderLength="190" SliderName="{SLoc DIYFFBPedalPlugin_TextGeneralSettingServoIdleTimeout, 'Servo Idle Timeout'}" TickFrequency="1" Unit="mins" Width="200" Height="40" MaxValue="50" SliderValueChanged="Slider_ServoTimeoutValueChanged" Margin="70,0,0,0" ToolTip="Only work with PCBA v2, set to 0 to turn off the function"/>
                </StackPanel>
            </StackPanel>

        </Border>
    </Grid>
</UserControl>
