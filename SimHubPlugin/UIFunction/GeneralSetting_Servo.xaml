<UserControl x:Class="DiyFfbPedal.UIFunction.GeneralSetting_Servo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:localUI="clr-namespace:DiyFfbPedal.UIElement"
             xmlns:localFunction="clr-namespace:DiyFfbPedal.UIFunction"
             xmlns:styles="clr-namespace:SimHub.Plugins.Styles;assembly=SimHub.Plugins"
             xmlns:ui="clr-namespace:SimHub.Plugins.UI;assembly=SimHub.Plugins"
             xmlns:controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="580"
             d:DataContext="{d:DesignInstance Type=localFunction:GeneralSetting_Servo}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/DiyFfbPedal;component/UIStyles/DefaultStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <!-- Column header style -->
            <Style x:Key="HeaderStyle" TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="#FF303030"/>
                <Setter Property="Foreground" Value="#FFD0D0D0"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding" Value="6,4"/>
                <Setter Property="BorderBrush" Value="#FF555555"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
            </Style>
            <!-- Row style: alternate shading -->
            <Style x:Key="RowStyle" TargetType="DataGridRow">
                <Setter Property="Background" Value="#FF2A2A2A"/>
                <Style.Triggers>
                    <Trigger Property="AlternationIndex" Value="1">
                        <Setter Property="Background" Value="#FF323232"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#FF3A3A5A"/>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#FF2D5A8E"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <!-- Cell style -->
            <Style x:Key="CellStyle" TargetType="DataGridCell">
                <Setter Property="Foreground" Value="#FFDADADA"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="4,2"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Foreground" Value="White"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- Outer scroll so everything is reachable when panel is small -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="4,4,4,8">

            <!-- ??? Servo Settings (sliders) ??????????????????????????????? -->
            <Border Background="#7F4E4E4E"
                    CornerRadius="5" BorderThickness="0,2,0,0"
                    Margin="0,0,0,6" Padding="0,4,0,8">
                <StackPanel>
                    <Label Content="{SLoc DIYFFBPedalPlugin_TextServoSettingTittle, 'Servo Settings'}"
                           Height="20" Padding="70,0,0,0"
                           VerticalContentAlignment="Center"
                           FontFamily="Arial Black"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <localUI:SliderWithLabel
                            x:Name="Slider_ServoEndstopDetecionThreshold"
                            SliderLength="190"
                            SliderName="{SLoc DIYFFBPedalPlugin_TextServoSettingSliderEndstopCurrent, 'Endstop Detection Threshold'}"
                            Width="200" Height="40"
                            SliderValue="30" MinValue="10" MaxValue="50"
                            TickFrequency="1" Unit="%"
                            Margin="70,0,0,0"
                            SliderValueChanged="Slider_ServoEndstopDetecionThreshold_SliderValueChanged"
                            ToolTip="Increase if homing does not reach full travel. Takes effect after config reset and pedal restart."/>
                        <localUI:SliderWithLabel
                            x:Name="Slider_ServoTimeout"
                            SliderLength="190"
                            SliderName="{SLoc DIYFFBPedalPlugin_TextGeneralSettingServoIdleTimeout, 'Servo Idle Timeout'}"
                            Width="200" Height="40"
                            MaxValue="50" TickFrequency="1" Unit="mins"
                            Margin="10,0,0,0"
                            SliderValueChanged="Slider_ServoTimeoutValueChanged"
                            ToolTip="Only works with PCBA v2. Set to 0 to disable."/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ??? Servo Register Table ???????????????????????????????????? -->
            <Border Background="#7F4E4E4E"
                    CornerRadius="5" BorderThickness="0,2,0,0"
                    Padding="8,6,8,8">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4" VerticalAlignment="Center">
                        <Label Content="Servo Registers"
                               FontFamily="Arial Black"
                               Foreground="White"
                               Padding="0,0,8,0"
                               VerticalContentAlignment="Center"/>
                        <Button Content="Load from servo"
                                x:Name="Btn_LoadFromServo"
                                Click="Btn_LoadFromServo_Click"
                                FontSize="8" Padding="3,1" Margin="0,0,3,0"
                                VerticalAlignment="Center"/>
                        <Button Content="Reset to recommended"
                                x:Name="Btn_ResetToRecommended"
                                Click="Btn_ResetToRecommended_Click"
                                FontSize="8" Padding="3,1" Margin="0,0,3,0"
                                VerticalAlignment="Center"/>
                        <Button Content="Reset to factory"
                                x:Name="Btn_ResetToFactory"
                                Click="Btn_ResetToFactory_Click"
                                FontSize="8" Padding="3,1" Margin="0,0,3,0"
                                VerticalAlignment="Center"
                                ToolTip="Calls Isv57Communication::resetToFactoryParams() on the servo (sets debugFlags0 bit 32, requires power-cycle)"/>
                        <Button Content="Flash to servo"
                                x:Name="Btn_FlashToServo"
                                Click="Btn_FlashToServo_Click"
                                FontSize="8" Padding="3,1"
                                VerticalAlignment="Center"
                                ToolTip="Writes 0x5555 to register 0x019A — forces the servo to persist all parameters to NVM (requires power-cycle)"/>
                    </StackPanel>

                    <DataGrid x:Name="ServoRegisterGrid"
                              ItemsSource="{Binding ServoRegisters,
                                  RelativeSource={RelativeSource AncestorType=localFunction:GeneralSetting_Servo}}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              CanUserSortColumns="True"
                              CanUserResizeColumns="True"
                              SelectionMode="Single"
                              AlternatingRowBackground="#FF323232"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#FF404040"
                              BorderThickness="1"
                              BorderBrush="#FF555555"
                              ColumnHeaderStyle="{StaticResource HeaderStyle}"
                              RowStyle="{StaticResource RowStyle}"
                              CellStyle="{StaticResource CellStyle}"
                              EnableRowVirtualization="False"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                              CellEditEnding="ServoRegisterGrid_CellEditEnding"
                              PreviewMouseWheel="ServoRegisterGrid_PreviewMouseWheel">

                        <DataGrid.Columns>
                            <!-- Address -->
                            <DataGridTemplateColumn Header="Register"
                                                    Width="80"
                                                    IsReadOnly="True"
                                                    SortMemberPath="Index">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Address}"
                                                   ToolTip="{Binding Name}"
                                                   VerticalAlignment="Center"
                                                   Foreground="#FF9ECFFF"
                                                   Padding="4,2"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Full name (read-only) -->
                            <DataGridTextColumn Header="Name"
                                                Binding="{Binding Name}"
                                                Width="*"
                                                IsReadOnly="True"/>

                            <!-- Live value – editable; sends to servo on commit -->
                            <DataGridTemplateColumn Header="Live (Servo)"
                                                    Width="105"
                                                    SortMemberPath="LiveValue">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding LiveValueDisplay}"
                                                   Foreground="{Binding LiveValueColor}"
                                                   VerticalAlignment="Center"
                                                   Padding="4,2"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding LiveValue,
                                                     UpdateSourceTrigger=LostFocus}"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 Foreground="#FFDADADA"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- Recommended value (read-only, muted color) -->
                            <DataGridTemplateColumn Header="Recommended"
                                                    Width="105"
                                                    IsReadOnly="True"
                                                    SortMemberPath="RecommendedValue">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RecommendedValue}"
                                                   Foreground="#FF888888"
                                                   VerticalAlignment="Center"
                                                   Padding="4,2"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
