<UserControl x:Class="User.PluginSdkDemo.UIFunction.GeneralSetting_Dynamics"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:User.PluginSdkDemo.UIFunction"
             xmlns:localUI="clr-namespace:User.PluginSdkDemo.UIElement"
             xmlns:localFunction="clr-namespace:User.PluginSdkDemo.UIFunction"
             xmlns:styles="clr-namespace:SimHub.Plugins.Styles;assembly=SimHub.Plugins" mc:Ignorable="d" 
             xmlns:ui="clr-namespace:SimHub.Plugins.UI;assembly=SimHub.Plugins" 
             xmlns:controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
             d:DesignHeight="190" d:DesignWidth="540"
             d:DataContext="{d:DesignInstance Type=localFunction:GeneralSetting_Dynamics}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/DiyActivePedal;component/UIStyles/DefaultStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Border Background="#7F4E4E4E" Height="190" CornerRadius="5,5,5,5" BorderThickness="0,2,0,0" >
            <StackPanel HorizontalAlignment="Left" Height="190" VerticalAlignment="Top" Width="540">
                <StackPanel Height="20" Width="540" Orientation="Horizontal">
                    <Label Content="Pedal Dynamics" Height="15" Width="150" Padding="0,0,0,0" VerticalContentAlignment="Center" FontFamily="Arial Black" HorizontalAlignment="Left" Margin="70,0,0,0"/>
                </StackPanel>
                <StackPanel Width="400" Height="50" Margin="0,0,0,0">
                    <localUI:SliderWithLabel x:Name="Slider_VirtualPedalMass" SliderLength="400" SliderName="{SLoc DIYFFBPedalPlugin_TextDynamicsSettingSliderVirtualPedalMass, 'Virtual Pedal Mass'}" SliderValue="0.3" MinValue="0.1" MaxValue="2.55"  TickFrequency="0.01" Unit="kg" SliderValueChanged="Slider_VirtualPedalMassChanged" ToolTip="Increase the value for stiffer pedal. Will increase likelihood of pedal oscillation."/>
                </StackPanel>
                <StackPanel Height="40" Width="540" HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal">
                    <localUI:SliderWithLabel x:Name="Slider_VirtualDamping" SliderLength="190" SliderName="{SLoc DIYFFBPedalPlugin_TextDynamicsSettingSliderVirtualPedalDamping, 'Virtual Pedal Damping (zeta value)'}" Width="200" Height="40" SliderValue="130" MinValue="50" MaxValue="255" SliderValueChanged="Slider_VirtualPedalDampingChanged" TickFrequency="1" Unit="%" ToolTip="Increase the value for stiffer pedal. Will increase likelihood of pedal oscillation." Margin="70,0,0,0"/>
                    <localUI:SliderWithLabel x:Name="Slider_DampingProgression" SliderLength="190" SliderName="{SLoc DIYFFBPedalPlugin_TextDynamicsSettingSliderPedalProgression, 'Damping progression (Elastomere)'}" Width="200" Height="40" SliderValue="0" MinValue="0" MaxValue="100" SliderValueChanged="Slider_DampingProgressionChanged" TickFrequency="1" Unit="%" ToolTip="Uses Hunt_Crossley model to emulate elastomere damping.     0%: metal spring.    100%: elastomere." Loaded="Slider_DampingProgression_Loaded"/>
                </StackPanel>
                <StackPanel Height="40" Width="540" HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal">
                    <localUI:SliderWithLabel x:Name="Slider_SoftEndstopTravelRange" SliderLength="190" SliderName="{SLoc DIYFFBPedalPlugin_TextDynamicsSettingSliderEndstopTravel, 'Endstop Travel'}" TickFrequency="0.1" Unit="mm" Width="200" Height="40" MinValue="0" MaxValue="10" SliderValueChanged="Slider_SoftEndstopTravelRangeChanged" Margin="70,0,0,0"/>
                    <localUI:SliderWithLabel x:Name="Slider_SoftEndstopStiffness" SliderLength="190" SliderName="{SLoc DIYFFBPedalPlugin_TextDynamicsSettingSliderEndstopStiffness, 'Endstop Stiffness'}" TickFrequency="1" Unit="kg/mm" Width="200" Height="40" MinValue="10" MaxValue="200" SliderValueChanged="Slider_SoftEndstopStiffnessChanged"/>
                </StackPanel>


            </StackPanel>

        </Border>
    </Grid>
</UserControl>
