<Window x:Class="User.PluginSdkDemo.UIFunction.FirmwareFlasherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:styles="clr-namespace:SimHub.Plugins.Styles;assembly=SimHub.Plugins"
        Title="USB Firmware Flasher" Height="350" Width="500" Background="#252525" WindowStyle="ToolWindow" ResizeMode="NoResize">
    <Grid>
        <Border Background="#7F4E4E4E" CornerRadius="5" BorderThickness="0,2,0,0">
            <StackPanel Margin="10">
                <Label Content="ESP32-S3 Firmware Update" FontSize="15" FontFamily="Arial Black" Foreground="White" HorizontalAlignment="Center"/>
                
                <StackPanel Orientation="Horizontal" Margin="0,10,0,5">
                    <Label Content="COM Port:" Width="80" Foreground="White" VerticalAlignment="Center"/>
                    <ComboBox x:Name="CboComPorts" Width="100" Height="25"/>
                    <styles:SHButtonPrimary x:Name="BtnRefreshCom" Content="Refresh" Width="70" Height="25" Margin="5,0,0,0" Click="BtnRefreshCom_Click"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,5,0,10">
                    <Label Content="Firmware:" Width="80" Foreground="White" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtBinPath" Width="240" Height="25" IsReadOnly="True" Background="#333" Foreground="White"/>
                    <styles:SHButtonPrimary Content="Browse..." Width="70" Height="25" Margin="5,0,0,0" Click="BtnBrowse_Click"/>
                </StackPanel>

                <styles:SHButtonPrimary x:Name="BtnFlash" Content="Flash Firmware" Height="30" Click="BtnFlash_Click"/>

                <TextBox x:Name="TxtLog" Height="130" Margin="0,10,0,0" IsReadOnly="True" Background="#1E1E1E" Foreground="LightGreen" FontFamily="Consolas" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>