                            <Label Content="{SLoc DIYFFBPedalPlugin_TextEffectCustom3Tittle, 'Custom Effect 3'}" Padding="0,0,0,0" VerticalContentAlignment="Center" FontFamily="Arial Black" Width="200" Height="15" HorizontalAlignment="Left" Margin="4,0,0,0"/>
                        </StackPanel>
                        <StackPanel  Height="40" Width="400" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Label Content="Effect NCalc &#10;Binding:" Height="40" Width="65" Padding="0,0,0,0" VerticalContentAlignment="Center" FontFamily="Arial" HorizontalAlignment="Left" FontSize="10" HorizontalContentAlignment="Center"/>
                            <TextBox x:Name="textBox_CV3_string" TextChanged="textBox_CV3_string_TextChanged" Width="270" Height="38"  Margin="2,0,0,0" HorizontalAlignment="Left" MinHeight="20" FontSize="9" ToolTip="Binding NCALC here" BorderThickness="0,0,0,0" TextWrapping="Wrap" ScrollViewer.CanContentScroll="True" VerticalScrollBarVisibility="Auto"/>
                            <StackPanel Height="40" Width="62" VerticalAlignment="Top">
                                <Label x:Name="Label_NCALC_CUS3" Content="" Height="20" Width="62" Padding="0,0,0,0" VerticalContentAlignment="Center" FontFamily="Arial" FontSize="10"/>
                                <StackPanel Orientation="Horizontal" Height="20" Width="62">
                                    <styles:SHButtonPrimary x:Name="Bind_CV3" Click="Bind_CV3_Click" Width="30" Content="{SLoc DIYFFBPedalPlugin_TextBtnBind, 'Bind'}" Height="20" Margin="0,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="0,0,0,0" VerticalContentAlignment="Center" FontFamily="Arial" FontSize="10" MinHeight="20" />
                                    <styles:SHButtonPrimary x:Name="Clear_CV3" Click="Clear_CV3_Click" Width="30" Content="{SLoc DIYFFBPedalPlugin_TextBtnClear, 'Clear'}" Height="20" Margin="2,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="0,0,0,0" VerticalContentAlignment="Center" FontFamily="Arial" FontSize="10" MinHeight="20" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        <localUI:SliderWithLabel x:Name="Slider_CV3_trigger" Width="400" Height="40" SliderLength="400" SliderName="{SLoc DIYFFBPedalPlugin_TextEffectCustomTrigger, 'Effect Trigger'}" SliderValueChanged="Slider_CV3_trigger_SliderValueChanged"/>
                        <localUI:SliderWithLabel x:Name="Slider_CV3_AMP" Width="400" Height="40" SliderLength="400" Unit="%" MaxValue="20" TickFrequency="0.1" SliderName="{SLoc DIYFFBPedalPlugin_TextEffectCustomAmp, 'Effect Amplitude'}" SliderValueChanged="Slider_CV3_AMP_SliderValueChanged"/>
                        <localUI:SliderWithLabel x:Name="Slider_CV3_freq" Width="400" Height="40" MinValue="10" MaxValue="50" SliderValue="10" Unit="Hz" SliderName="{SLoc DIYFFBPedalPlugin_TextEffectCustomFreq, 'Effect Frequency'}" SliderValueChanged="Slider_CV3_freq_SliderValueChanged" SliderLength="400"/>
                    </StackPanel>
                </Border>
            </TabItem>
            <TabItem Width="100" Height="30" Padding="0,0,0,0" Margin="0,0,0,0" VerticalContentAlignment="Center">
                <TabItem.Header >
                    <Border  Width="100" Height="30" Margin="0,0,0,0" >
                        <Label Content="{SLoc DIYFFBPedalPlugin_TabItemCustom4, 'CUSTOM4'}"  FontFamily="Arial Black" FontSize="12" Height="30" Width="100" Padding="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  />
                    </Border>
                </TabItem.Header>
                <Border Background="#7F4E4E4E" CornerRadius="5,5,5,5" Height="240" BorderThickness="0,0,0,0" Width="437" >
                    <StackPanel Height="240" VerticalAlignment="Top" Width="437">
                        <StackPanel Height="20" Width="400" Orientation="Horizontal" HorizontalAlignment="Left">
