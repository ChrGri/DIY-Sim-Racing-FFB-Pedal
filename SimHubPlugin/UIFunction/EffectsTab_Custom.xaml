                            <Label Content="{SLoc DIYFFBPedalPlugin_TextEffectCustom4Tittle, 'Custom Effect 4'}" Padding="0,0,0,0" VerticalContentAlignment="Center" FontFamily="Arial Black" Width="200" Height="15" HorizontalAlignment="Left" Margin="4,0,0,0"/>
