<UserControl x:Class="User.PluginSdkDemo.UIFunction.EffectsTab_Custom"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
            xmlns:local="clr-namespace:User.PluginSdkDemo.UIFunction"
            xmlns:localUI="clr-namespace:User.PluginSdkDemo.UIElement"
            xmlns:styles="clr-namespace:SimHub.Plugins.Styles;assembly=SimHub.Plugins" mc:Ignorable="d" 
            xmlns:controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
            d:DesignHeight="240" d:DesignWidth="540">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/DiyActivePedal;component/UIStyles/DefaultStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <TabControl TabStripPlacement="Left" BorderThickness="0,0,0,0" Background="#00252525" Foreground="Transparent" Padding="0,0,0,0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <!--The four values of CornerRadius represent the four corners of the TabItem.-->
                                <Border Name="Border" BorderThickness="0,0,0,0" BorderBrush="Gainsboro" CornerRadius="5,5,5,5" Margin="0,0,2,2">
                                    <ContentPresenter x:Name="ContentSite"  
                                    VerticalAlignment="Center"  
                                    HorizontalAlignment="Left"  
                                    ContentSource="Header"  
                                    Margin="0,0"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#7F4E4E4E" />
                                        <Setter Property="TextElement.Foreground" Value="#FFFFFFFF" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter TargetName="Border" Property="Background" Value="#334E4E4E" />
                                        <Setter Property="TextElement.Foreground" Value="#7FFFFFFF" />
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsMouseOver" SourceName="Border" Value="True"/>
                                            <Condition Property="IsSelected" Value="False"/>
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="Border" Property="Background" Value="#4C4E4E4E" />
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>
            <TabItem Width="100" Height="30" Padding="0,0,0,0">
                <TabItem.Header >
                    <Border  Width="100" Height="30" Margin="0,0,0,0" >
                        <Label Content="{SLoc DIYFFBPedalPlugin_TabItemCustom1, 'CUSTOM1'}"  FontFamily="Arial Black" FontSize="12" Height="30" Width="100" Padding="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  />
                    </Border>
                </TabItem.Header>
                <Border Background="#7F4E4E4E" CornerRadius="5,5,5,5" Height="240" BorderThickness="0,0,0,0" Width="437" >
                    <StackPanel HorizontalAlignment="Left" Height="240" VerticalAlignment="Top" Width="437">
                        <StackPanel Height="20" Width="400" Orientation="Horizontal" HorizontalAlignment="Left">
                            <styles:SHToggleButton x:Name="checkbox_enable_CV1" Content="" Checked="checkbox_enable_CV1_Checked" Unchecked="checkbox_enable_CV1_Unchecked" IsChecked="False" FontSize="10" Width="35" Height="15" HorizontalAlignment="Left" FontFamily="Arial" ToolTip="The effect trigger was save in local, no need send config to Pedal"/>
                            <Label Content="{SLoc DIYFFBPedalPlugin_TextEffectCustom1Tittle, 'Custom Effect 1'}" Padding="0,0,0,0" VerticalContentAlignment="Center" FontFamily="Arial Black" Width="200" Height="15" HorizontalAlignment="Left" Margin="4,0,0,0"/>
                        </StackPanel>
                        <StackPanel  Height="40" Width="400" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Label Content="Effect NCalc &#10;Binding:" Height="40" Width="65" Padding="0,0,0,0" VerticalContentAlignment="Center" FontFamily="Arial" HorizontalAlignment="Left" FontSize="10" HorizontalContentAlignment="Center"/>
                            <TextBox x:Name="textBox_CV1_string" TextChanged="textBox_CV1_string_TextChanged" Width="270" Height="38"  Margin="2,0,0,0" HorizontalAlignment="Left" MinHeight="20" FontSize="9" ToolTip="Binding NCALC here" BorderThickness="0,0,0,0" TextWrapping="Wrap" ScrollViewer.CanContentScroll="True" VerticalScrollBarVisibility="Auto"/>
                            <StackPanel Height="40" Width="62" VerticalAlignment="Top">
                                <Label x:Name="Label_NCALC_CUS1" Content="" Height="20" Width="62" Padding="0,0,0,0" VerticalContentAlignment="Center" FontFamily="Arial" FontSize="10"/>
                                <StackPanel Orientation="Horizontal" Height="20" Width="62">
                                    <styles:SHButtonPrimary x:Name="Bind_CV1" Click="Bind_CV1_Click" Width="30" Content="{SLoc DIYFFBPedalPlugin_TextBtnBind, 'Bind'}" Height="20" Margin="0,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="0,0,0,0" VerticalContentAlignment="Center" FontFamily="Arial" FontSize="10" MinHeight="20" />
                                    <styles:SHButtonPrimary x:Name="Clear_CV1" Click="Clear_CV1_Click" Width="30" Content="{SLoc DIYFFBPedalPlugin_TextBtnClear, 'Clear'}" Height="20" Margin="2,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="0,0,0,0" VerticalContentAlignment="Center" FontFamily="Arial" FontSize="10" MinHeight="20" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        <localUI:SliderWithLabel x:Name="Slider_CV1_trigger" Width="400" Height="40" SliderLength="400" SliderName="{SLoc DIYFFBPedalPlugin_TextEffectCustomTrigger, 'Effect Trigger'}" SliderValueChanged="Slider_CV1_trigger_SliderValueChanged"/>
                        <localUI:SliderWithLabel x:Name="Slider_CV1_AMP" Width="400" Height="40" SliderLength="400" Unit="%" MaxValue="20" TickFrequency="0.1" SliderName="{SLoc DIYFFBPedalPlugin_TextEffectCustomAmp, 'Effect Amplitude'}" SliderValueChanged="Slider_CV1_AMP_SliderValueChanged"/>
                        <localUI:SliderWithLabel x:Name="Slider_CV1_freq" Width="400" Height="40" MinValue="10" MaxValue="50" SliderValue="10" Unit="Hz" SliderName="{SLoc DIYFFBPedalPlugin_TextEffectCustomFreq, 'Effect Frequency'}" SliderValueChanged="Slider_CV1_freq_SliderValueChanged" SliderLength="400"/>

                    </StackPanel>
                </Border>
            </TabItem>
            <TabItem Width="100" Height="30" Padding="0,0,0,0" Margin="0,0,0,0" VerticalContentAlignment="Center">
                <TabItem.Header >
                    <Border  Width="100" Height="30" Margin="0,0,0,0" >
