                        <localUI:SliderWithLabel x:Name="Slider_CV2_trigger" Width="400" Height="40" SliderLength="400" SliderName="{SLoc DIYFFBPedalPlugin_TextEffectCustomTrigger, 'Effect Trigger'}" SliderValueChanged="Slider_CV2_trigger_SliderValueChanged"/>
                        <localUI:SliderWithLabel x:Name="Slider_CV2_AMP" Width="400" Height="40" SliderLength="400" Unit="%" MaxValue="20" TickFrequency="0.1" SliderName="{SLoc DIYFFBPedalPlugin_TextEffectCustomAmp, 'Effect Amplitude'}" SliderValueChanged="Slider_CV2_AMP_SliderValueChanged"/>
                        <localUI:SliderWithLabel x:Name="Slider_CV2_freq" Width="400" Height="40" MinValue="10" MaxValue="50" SliderValue="10" Unit="Hz" SliderName="{SLoc DIYFFBPedalPlugin_TextEffectCustomFreq, 'Effect Frequency'}" SliderValueChanged="Slider_CV2_freq_SliderValueChanged" SliderLength="400"/>
                    </StackPanel>
                </Border>
            </TabItem>
            <TabItem Width="100" Height="30" Padding="0,0,0,0" Margin="0,0,0,0" VerticalContentAlignment="Center">
                <TabItem.Header >
                    <Border  Width="100" Height="30" Margin="0,0,0,0" >
