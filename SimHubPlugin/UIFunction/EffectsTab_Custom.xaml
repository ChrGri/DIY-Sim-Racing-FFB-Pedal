                    </Border>
                </TabItem.Header>
                <Border Background="#7F4E4E4E" CornerRadius="5,5,5,5" Height="240" BorderThickness="0,0,0,0" Width="437" >
                    <StackPanel Height="240" VerticalAlignment="Top" Width="437">
                        <StackPanel Height="20" Width="400" Orientation="Horizontal" HorizontalAlignment="Left">
                            <styles:SHToggleButton x:Name="checkbox_enable_CV2" Content="" Checked="checkbox_enable_CV2_Checked" Unchecked="checkbox_enable_CV2_Unchecked" IsChecked="False" FontSize="10" Width="35" Height="15" HorizontalAlignment="Left" FontFamily="Arial" ToolTip="The effect trigger was save in local, no need send config to Pedal"/>
                            <Label Content="{SLoc DIYFFBPedalPlugin_TextEffectCustom2Tittle, 'Custom Effect 2'}" Padding="0,0,0,0" VerticalContentAlignment="Center" FontFamily="Arial Black" Width="200" Height="15" HorizontalAlignment="Left" Margin="4,0,0,0"/>
                        </StackPanel>
                        <StackPanel  Height="40" Width="400" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Label Content="Effect NCalc &#10;Binding:" Height="40" Width="65" Padding="0,0,0,0" VerticalContentAlignment="Center" FontFamily="Arial" HorizontalAlignment="Left" FontSize="10" HorizontalContentAlignment="Center"/>
                            <TextBox x:Name="textBox_CV2_string" TextChanged="textBox_CV2_string_TextChanged" Width="270" Height="38"  Margin="2,0,0,0" HorizontalAlignment="Left" MinHeight="20" FontSize="9" ToolTip="Binding NCALC here" BorderThickness="0,0,0,0" TextWrapping="Wrap" ScrollViewer.CanContentScroll="True" VerticalScrollBarVisibility="Auto"/>
                            <StackPanel Height="40" Width="62" VerticalAlignment="Top">
                                <Label x:Name="Label_NCALC_CUS2" Content="" Height="20" Width="62" Padding="0,0,0,0" VerticalContentAlignment="Center" FontFamily="Arial" FontSize="10"/>
                                <StackPanel Orientation="Horizontal" Height="20" Width="62">
                                    <styles:SHButtonPrimary x:Name="Bind_CV2" Click="Bind_CV2_Click" Width="30" Content="{SLoc DIYFFBPedalPlugin_TextBtnBind, 'Bind'}" Height="20" Margin="0,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="0,0,0,0" VerticalContentAlignment="Center" FontFamily="Arial" FontSize="10" MinHeight="20" />
                                    <styles:SHButtonPrimary x:Name="Clear_CV2" Click="Clear_CV2_Click" Width="30" Content="{SLoc DIYFFBPedalPlugin_TextBtnClear, 'Clear'}" Height="20" Margin="2,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="0,0,0,0" VerticalContentAlignment="Center" FontFamily="Arial" FontSize="10" MinHeight="20" />
                                </StackPanel>
